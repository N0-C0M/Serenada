{
  "name": "@serenada/react-ui",
  "version": "0.1.0",
  "description": "Pre-built React call UI components for Serenada video calls",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:publish": "tsc -p tsconfig.build.json",
    "lint": "eslint src/",
    "test": "vitest run test",
    "prepublishOnly": "npm run build:publish"
  },
  "dependencies": {
    "@serenada/core": "0.1.0",
    "react-qr-code": "^2.0.17"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "lucide-react": ">=0.300.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AleGavrilov/serenada-sdk.git",
    "directory": "client/packages/react-ui"
  },
  "keywords": [
    "webrtc",
    "video-call",
    "react",
    "serenada"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
