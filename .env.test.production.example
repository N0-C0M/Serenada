# Test deployment overrides for deploy-test.sh

TEST_DOMAIN=test.serenada-app.ru
TEST_REMOTE_DIR=/opt/serenada-test
TEST_COMPOSE_PROJECT=serenada-test
TEST_APP_HTTP_PORT=18080
TEST_STACK_HTTP_PORT=18081

# Required only when the certificate for TEST_DOMAIN does not exist yet.
TEST_CERTBOT_EMAIL=ops@example.com

# Optional test-only app server overrides.
# Keep commented to inherit values from .env.production.
# ROOM_ID_ENV=test
# ALLOWED_ORIGINS=https://test.serenada-app.ru
